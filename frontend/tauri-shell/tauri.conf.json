{
  "productName": "Tyde",
  "mainBinaryName": "tyde",
  "version": "0.8.3",
  "identifier": "com.tyde.app",
  "build": {
    "beforeDevCommand": "node ../tools/trunk-command.mjs serve --port 1420",
    "beforeBuildCommand": "node ../tools/trunk-command.mjs build --release",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Tyde",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "dragDropEnabled": false
      }
    ]
  }
}
