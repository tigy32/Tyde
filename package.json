{
  "name": "tyde",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "tauri": "tauri",
    "test:e2e": "wdio run wdio.conf.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "check": "biome check src/ && tsc --noEmit && tsc -p tsconfig.test.json --noEmit && cargo check --manifest-path src-tauri/Cargo.toml && cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@tanstack/virtual-core": "^3.13.21",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tyde/protocol": "github:tigy32/TydeProtocol#f38d6d2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "diff": "^8.0.2",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.3",
    "modern-screenshot": "^4.6.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@tauri-apps/cli": "^2",
    "@types/mocha": "^10.0.10",
    "@wdio/cli": "^9",
    "@wdio/local-runner": "^9",
    "@wdio/mocha-framework": "^9",
    "@wdio/spec-reporter": "^9",
    "chromedriver": "^136",
    "ts-node": "^10",
    "typescript": "~5.6",
    "vite": "^6",
    "vitepress": "^1.6.4",
    "webdriverio": "^9"
  }
}
