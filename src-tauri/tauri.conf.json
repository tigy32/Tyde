{
  "productName": "Tyde",
  "mainBinaryName": "tyde",
  "version": "0.7.0",
  "identifier": "com.tyde.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Tyde",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": false
      }
    ]
  }
}
